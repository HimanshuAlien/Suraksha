{
  "version": 2,
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/analyze", "destination": "/api/index.js" },
    { "source": "/scan-doc", "destination": "/api/index.js" },
    { "source": "/report", "destination": "/api/index.js" },
    { "source": "/reports", "destination": "/api/index.js" },
    { "source": "/api-status", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/**"
    }
  }
}
